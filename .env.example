# Copy this file to .env and fill in your real values.
# Never commit .env to git.

GEMINI_API_KEY=paste-your-key-here

# Optional: override model selection
LIFEOS_AGENT_MODEL=gemini-3.1-flash-lite
LIFEOS_JUDGE_MODEL=gemini-3.5-flash

# Optional: Adzuna API for Romania + 18 countries (free key at developer.adzuna.com)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Optional: Apify token for LinkedIn jobs scraping (free $5/mo at apify.com)
# Without this, LinkedIn source is silently skipped.
APIFY_TOKEN=
# Default LinkedIn actor on Apify Store; override if you prefer a different one.
APIFY_LINKEDIN_ACTOR=bebity~linkedin-jobs-scraper
